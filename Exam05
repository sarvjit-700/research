#include <unistd.h>
#include <stdlib.h>
#include <stdio.h>

int count(char *b, int x, int y, int w, int h)
{
    int dx,dy,n;
    n = 0;

    dy = -1;
    while (dy <= 1)
    {
        dx = -1;
        while (dx <= 1)
        {
            if (dx || dy)
            {
                int nx = x +dx;
                int ny = y +dy;
                if (nx >= 0 && nx < w && ny >= 0 && ny < h && b[ny*w+nx])
                    n++;
            }
            dx++;
        }
        dy++;
    }
    return n;
}


void    step(char *b, char *nxt, int w, int h)
{
    int x, y, nb;

    y = 0;
    while(y < h)
    {
        x = 0;
        while (x < w)
        {
            nb = count(b, x, y, w, h);
            if (b[y*w+x])
                nxt[y*w+x] = (nb == 2 || nb == 3);
            else
                nxt[y*w+x] = (nb == 3);
            x++;
        }
        y++;
    }
}

