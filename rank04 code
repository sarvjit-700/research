#include <unistd.h>
#include <sys/wait.h>
#include <stdlib.h>

int picoshell(char **cmds[])
{
    int i;
    int pipe_fd[2];
    int prev_fd;
    pid_t pid;

    i = 0;
    prev_fd = -1;
    while (cmds[i])
    {
        if (cmds[i+1])
        {
            if (pipe(pipe_fd) == -1)
                return (1);
        }
        pid = fork();
        if (pid == -1)
        {
            if (cmds[i+1])
            {
                close(pipe_fd[0]);
                close(pipe_fd[1]);
            }
            return (1);
        }
        if (pid == 0)
        {
            if (prev_fd != -1)
            {
                if (dup2(prev_fd, STDIN_FILENO) == -1)
                    exit(1);
                close(prev_fd);
            }
            if (cmds[i+1])
            {
                close(pipe_fd[0]);
                if (dup2(pipe_fd[1], STDOUT_FILENO) == -1)
                    exit(1);
                close(pipe_fd[1]);
            }
            execvp(cmds[i][0], cmds[i]);
            exit(1);
        }
        if (prev_fd != -1)
            close(prev_fd);
        if (cmds[i+1])
        {
            close(pipe_fd[1]);
            prev_fd = pipe_fd[0];
        }
        i++;       
    }

    while (wait(NULL) > 0);
    return (0);
}
