#include "bsq.h"


int main(int ac, char **av)
{
    if (ac == 1)
    {
        // Read directly from Standard Input (e.g. cat map | ./a.out)
        solve_bsq(0);
    }
    else
    {
        // Loop through multiple file targets arguments sequentially
        for (int i = 1; i < ac; i++)
        {
            int fd = open(av[i], O_RDONLY);
            if (fd < 0)
            {
                write(2, "map error\n", 10);
            }
            else
            {
                solve_bsq(fd);
                close(fd);
            }
        }
    }
    return (0);
}

